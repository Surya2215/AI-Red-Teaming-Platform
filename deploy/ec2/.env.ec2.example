# Copy this file to .env on the EC2 instance and fill in real values.
# Do not commit your real .env file.

LOG_LEVEL=INFO

# Database used by the API container in docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://redteam:redteam@postgres:5432/redteam

# RabbitMQ broker and Valkey result backend.
# For all-in-one docker compose, keep hostnames as rabbitmq and valkey.
CELERY_BROKER_URL=amqp://redteam:redteam@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://valkey:6379/0
CELERY_TASK_DEFAULT_QUEUE=tool-scans
TOOL_WORKER_ENABLED=true

# Optional LLM provider settings used by the platform.
LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Optional alternatives.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

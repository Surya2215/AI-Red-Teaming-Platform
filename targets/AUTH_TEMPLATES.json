{
  "_comment": "AUTHENTICATION TEMPLATES - Dynamically applicable for all applications",
  "_description": "This file demonstrates all supported authentication patterns in the LLM Red Teaming platform. Choose the pattern that matches your target application and customize URLs, paths, and field names.",
  "name": "[REFERENCE] Authentication Templates",
  
  "auth_types": {
    
    "none": {
      "description": "No authentication required",
      "use_case": "Public APIs, mock targets, or applications without auth",
      "template": {
        "type": "none"
      }
    },

    "bearer_token_from_env": {
      "description": "Bearer token injected from environment variable",
      "use_case": "APIs using Bearer tokens stored in environment",
      "setup": "Set env var: export API_TOKEN=your_token_here",
      "template": {
        "type": "bearer",
        "token_env": "API_TOKEN"
      }
    },

    "bearer_token_in_header": {
      "description": "Bearer token passed directly in headers",
      "use_case": "Static bearer token in application config",
      "template": {
        "type": "none",
        "headers": {
          "Authorization": "Bearer YOUR_STATIC_TOKEN_HERE"
        }
      }
    },

    "api_key_header": {
      "description": "API key in custom header",
      "use_case": "APIs using custom API key headers",
      "template": {
        "type": "none",
        "headers": {
          "X-API-Key": "YOUR_API_KEY_HERE"
        }
      }
    },

    "basic_auth": {
      "description": "HTTP Basic Authentication (credentials in header)",
      "use_case": "Simple username:password authentication",
      "note": "Implement base64 encoding in your request template",
      "template": {
        "type": "none",
        "headers": {
          "Authorization": "Basic YOUR_BASE64_CREDENTIALS_HERE"
        }
      }
    },

    "session_cookie_auth": {
      "description": "Login to get session cookie, use in subsequent requests",
      "use_case": "Traditional web applications with session-based auth",
      "flow": "POST /login → extract session → use in Cookie header",
      "template": {
        "type": "session",
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/login",
            "headers": {
              "Content-Type": "application/x-www-form-urlencoded"
            },
            "body": {
              "username": "{{username}}",
              "password": "{{password}}"
            },
            "response_session_id_path": "session_id"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/chat",
            "headers": {
              "Content-Type": "application/json",
              "Cookie": "session={{session_id}}"
            },
            "body": {
              "message": "{{prompt}}"
            },
            "response_message_path": "response"
          }
        }
      }
    },

    "oauth2_authorization_code": {
      "description": "OAuth 2.0 Authorization Code Flow - get token then use",
      "use_case": "OAuth2-protected APIs",
      "flow": "POST /token → extract access_token → use in Authorization header",
      "template": {
        "type": "session",
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://auth.example.com/token",
            "headers": {
              "Content-Type": "application/x-www-form-urlencoded"
            },
            "body": {
              "grant_type": "password",
              "username": "{{username}}",
              "password": "{{password}}",
              "client_id": "YOUR_CLIENT_ID",
              "client_secret": "YOUR_CLIENT_SECRET"
            },
            "access_token_path": "access_token"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/chat",
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer {{access_token}}"
            },
            "body": {
              "message": "{{prompt}}"
            },
            "response_message_path": "response.text"
          }
        }
      }
    },

    "multi_step_auth_with_refresh": {
      "description": "Complex auth: login → get token & refresh token → use in requests",
      "use_case": "Applications with token rotation and refresh tokens",
      "template": {
        "type": "session",
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://auth.example.com/oauth/token",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "username": "{{username}}",
              "password": "{{password}}"
            },
            "access_token_path": "access_token",
            "response_session_id_path": "refresh_token"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/query",
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer {{access_token}}"
            },
            "body": {
              "query": "{{prompt}}"
            },
            "response_message_path": "data.result"
          }
        }
      }
    },

    "jwt_token_auth": {
      "description": "JWT token obtained from auth endpoint, used in Authorization header",
      "use_case": "JWT-based authentication",
      "flow": "POST /authenticate → extract jwt → use as Bearer token",
      "template": {
        "type": "session",
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/authenticate",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "email": "{{username}}",
              "password": "{{password}}"
            },
            "access_token_path": "token"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/message",
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer {{access_token}}"
            },
            "body": {
              "text": "{{prompt}}"
            },
            "response_message_path": "reply"
          }
        }
      }
    },

    "api_key_and_session": {
      "description": "Combine API key with session cookie",
      "use_case": "APIs requiring both static API key and session management",
      "template": {
        "type": "session",
        "headers": {
          "X-API-Key": "YOUR_API_KEY"
        },
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/login",
            "headers": {
              "Content-Type": "application/json",
              "X-API-Key": "YOUR_API_KEY"
            },
            "body": {
              "username": "{{username}}",
              "password": "{{password}}"
            },
            "response_session_id_path": "session_token"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/chat",
            "headers": {
              "Content-Type": "application/json",
              "X-API-Key": "YOUR_API_KEY",
              "X-Session-Token": "{{session_id}}"
            },
            "body": {
              "message": "{{prompt}}"
            },
            "response_message_path": "data.message"
          }
        }
      }
    },

    "custom_header_auth": {
      "description": "Custom authentication header (vendor-specific)",
      "use_case": "Proprietary APIs with custom auth schemes",
      "template": {
        "type": "none",
        "headers": {
          "X-Auth-Token": "YOUR_CUSTOM_TOKEN",
          "X-Client-ID": "YOUR_CLIENT_ID"
        }
      }
    },

    "graphql_auth": {
      "description": "GraphQL API with token in Authorization header",
      "use_case": "GraphQL endpoints with Bearer token authentication",
      "template": {
        "type": "session",
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://graphql.example.com/auth",
            "headers": {
              "Content-Type": "application/json"
            },
            "body": {
              "query": "mutation { login(username: \"{{username}}\", password: \"{{password}}\") { token } }",
              "operationName": "login"
            },
            "access_token_path": "data.login.token"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://graphql.example.com/graphql",
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer {{access_token}}"
            },
            "body": {
              "query": "query { chat(prompt: \"{{prompt}}\") { response } }",
              "operationName": "chat"
            },
            "response_message_path": "data.chat.response"
          }
        }
      }
    },

    "oauth2_client_credentials": {
      "description": "OAuth 2.0 Client Credentials Flow (service-to-service)",
      "use_case": "Service accounts and backend authentication",
      "template": {
        "type": "session",
        "workflow": {
          "credential_authentication": {
            "enabled": true,
            "method": "POST",
            "url": "https://auth.example.com/oauth/token",
            "headers": {
              "Content-Type": "application/x-www-form-urlencoded"
            },
            "body": {
              "grant_type": "client_credentials",
              "client_id": "{{username}}",
              "client_secret": "{{password}}"
            },
            "access_token_path": "access_token"
          },
          "next_turn": {
            "enabled": true,
            "method": "POST",
            "url": "https://api.example.com/chat",
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer {{access_token}}"
            },
            "body": {
              "message": "{{prompt}}"
            },
            "response_message_path": "response"
          }
        }
      }
    },

    "digest_auth": {
      "description": "HTTP Digest Authentication",
      "use_case": "Legacy systems using Digest auth",
      "note": "Requires custom implementation in request headers",
      "template": {
        "type": "none",
        "headers": {
          "Authorization": "Digest username={{username}}, realm=Protected, nonce=YOUR_NONCE"
        }
      }
    }

  },

  "implementation_guide": {
    "step_1_identify_auth": "Determine your target's authentication method",
    "step_2_select_template": "Find matching template above",
    "step_3_customize_urls": "Update endpoint URLs for your target",
    "step_4_adjust_paths": "Modify response_*_path to match your API's response structure",
    "step_5_set_credentials": "Provide username/password or environment variables",
    "step_6_test_response_paths": "Verify token/session extraction paths match actual responses",
    "step_7_configure_next_turn": "Ensure main request includes auth (Bearer, Cookie, etc.)"
  },

  "template_variables_available": {
    "prompt": "Attack prompt injected by the platform",
    "username": "Provided via scan request or environment variable",
    "password": "Provided via scan request or environment variable",
    "session_id": "Extracted from credential_authentication response",
    "access_token": "Extracted from credential_authentication response",
    "conversation_id": "Unique conversation identifier",
    "latest_message": "Same as prompt"
  },

  "path_extraction_guide": {
    "simple_field": "response_message_path: 'message'",
    "nested_object": "response_message_path: 'data.response.text'",
    "array_index": "response_message_path: 'data[0].token'",
    "deep_nested": "response_message_path: 'auth.tokens.access_token'"
  },

  "common_customization_points": {
    "response_message_path": "Where to extract the response text from API response",
    "access_token_path": "Where to extract token for Authorization header",
    "response_session_id_path": "Where to extract session ID/token from login response",
    "header_key_for_auth": "Custom header name for authentication token",
    "cookie_format": "Format of session cookie (e.g., 'session={{session_id}}')"
  }
}
